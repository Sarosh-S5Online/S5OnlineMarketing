{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/diensten", "destination": "/services", "permanent": true },
    { "source": "/webdesign", "destination": "/services/webdesign", "permanent": true },
    { "source": "/google-ads", "destination": "/services/google-ads", "permanent": true },
    { "source": "/meta-ads", "destination": "/services/meta-ads", "permanent": true },
    { "source": "/seo", "destination": "/services/seo", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(.*)\\.(mp4|webm)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
